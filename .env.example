# Claude Managed Agents on Blaxel -- environment template.
# Copy to .env, fill in, then load it:   set -a; source .env; set +a
# .env is gitignored. Never commit real keys.

# --- Always required: control plane + Blaxel spawn -------------------------
# Standard Anthropic API key. Control-plane calls only (create environment / agent / session).
# NEVER put this on a worker -- the agent's own bash tool could read worker env.
export ANTHROPIC_API_KEY=
# Blaxel service-account key + workspace. The orchestrator uses these to spawn worker
# sandboxes (a sandbox has no auto-injected Blaxel identity). Create one under Service Accounts.
export BL_API_KEY=
export BL_WORKSPACE=

# --- Self-hosted environment (from scripts/create_environment.py) ----------
export ANTHROPIC_ENVIRONMENT_ID=
# Generated in the Anthropic Console ("Generate environment key"). Scoped + revocable
# per environment, and the ONLY Anthropic secret that enters the worker process.
export ANTHROPIC_ENVIRONMENT_KEY=

# --- Agent id (from scripts/create_agent.py) -------------------------------
export ANTHROPIC_AGENT_ID=

# --- Webhook signing secret (from registering the webhook in the Console) --
# One-time signing secret shown when you create the webhook in the Console.
# Without this, the orchestrator returns 503; with a wrong value, it returns 401.
export ANTHROPIC_WEBHOOK_SIGNING_KEY=

# --- Optional tuning (sane defaults; override only if needed) --------------
# export BL_REGION=us-pdx-1                  # silences the SDK region warning
# export BLAXEL_WORKER_IMAGE=sandbox/cma-worker:latest
# export BLAXEL_WORKER_TTL=2h                # worker max-age cleanup backstop (m/h/d/w, NOT seconds)
# export ANT_MAX_IDLE=60s                    # ant run exits after session stop_reason=end_turn stays idle this long
# export ANT_KEEPALIVE_TIMEOUT=3600          # seconds; hard cap on a worker session (0 = run until natural exit)
# export ANT_DISPATCHER_POLL_BLOCK_MS=999    # SDK queue-drain long-poll cap; 1-999 ms
# export ANT_DISPATCHER_RECLAIM_MS=30000     # reclaim acked-but-unhandled work after this many ms
# export ANT_DISPATCHER_DEBOUNCE_MS=250      # collect near-simultaneous session webhooks before queue claim
# export ANTHROPIC_DISPATCHER_WORKER_ID=...  # optional stable Anthropic worker metric id for the orchestrator
# export ANTHROPIC_LOCAL_DISPATCHER_WORKER_ID=... # optional stable Anthropic worker metric id for --local-worker
# export ANT_RUN_START_ATTEMPTS=10           # bounded process-start retries after a claim
# export BLAXEL_WORKER_READY_ATTEMPTS=45      # orchestrator: readiness probes before a worker is considered failed
# export BLAXEL_WORKER_READY_SLEEP=2          # orchestrator: seconds between worker readiness probes
# export ANTHROPIC_BASE_URL=https://api.anthropic.com
# export ORCHESTRATOR_NAME=cma-orchestrator-app
# export ORCHESTRATOR_IMAGE=sandbox/cma-orchestrator:latest
# export ORCHESTRATOR_PORT=8000
# export ORCHESTRATOR_TTL=7d                  # orchestrator sandbox max age/lifecycle backstop
# export ORCHESTRATOR_KEEPALIVE_TIMEOUT=0     # keep webhook server active; 0 = run until natural exit
